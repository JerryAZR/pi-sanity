{
  "name": "@jerryan/pi-sanity",
  "version": "0.4.2",
  "description": "Pi extension for sanity checks on agent operations",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Jerry An <jerryan@gmx.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JerryAZR/pi-sanity.git"
  },
  "bugs": {
    "url": "https://github.com/JerryAZR/pi-sanity/issues"
  },
  "homepage": "https://github.com/JerryAZR/pi-sanity#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package",
    "agent",
    "ai",
    "safety",
    "sanity-checks",
    "bash",
    "security"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./extension": "./dist/extension.js"
  },
  "files": [
    "dist/src",
    "dist/extension.js",
    "dist/extension.d.ts",
    "skills"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "embed-config": "node scripts/embed-config.js",
    "build": "npm run embed-config && tsc",
    "test": "npm run build && node --test dist/tests/unit/**/*.test.js dist/tests/integration/**/*.test.js",
    "test:ci": "npm run build && node --test dist/tests/unit/**/*.test.js dist/tests/integration/**/*.test.js",
    "test:unit": "npm run build && node --test dist/tests/unit/**/*.test.js",
    "test:integration": "npm run build && node --test dist/tests/integration/**/*.test.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "picomatch": "^4.0.4",
    "smol-toml": "^1.6.1",
    "unbash": "^2.2.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.3",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ],
    "skills": [
      "./skills"
    ]
  }
}
