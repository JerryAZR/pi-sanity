{
  "name": "pi-sanity",
  "version": "0.1.0",
  "description": "Pi extension for sanity checks on agent operations",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "embed-config": "node scripts/embed-config.js",
    "build": "npm run embed-config && tsc",
    "test": "npm run build && node run-tests.js",
    "test:ci": "npm run build && node --test --test-reporter=./tests/reporter.js dist/tests/*.test.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "picomatch": "^4.0.4",
    "smol-toml": "^1.6.1",
    "unbash": "^2.2.0"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.3",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ]
  }
}
